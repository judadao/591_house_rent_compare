{
  "manifest_version": 3,
  "name": "591 Rent Average Compare",
  "description": "Show the average rent on 591 rental search pages and mark each listing above or below that average.",
  "version": "0.8.0",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "*://rent.591.com.tw/*"
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "重新標註本頁租金平均",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://rent.591.com.tw/*"
      ],
      "js": ["src/listingParser.js", "src/contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
